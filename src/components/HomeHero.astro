---
import { siteConfig } from "../config";
---

<section
	id="home-hero"
	class="relative flex min-h-[100svh] items-center justify-center px-6 pb-24 pt-28 md:items-end md:pb-28 md:pt-32"
>
	<div class="absolute inset-0 bg-gradient-to-b from-slate-950/6 via-slate-900/10 to-slate-950/34"></div>

	<div class="relative z-10 w-full max-w-6xl">
		<div class="mx-auto md:mx-0 md:max-w-[35rem] md:translate-y-[-7vh]">
			<div class="rounded-[2rem] border border-white/24 bg-[rgba(132,157,175,0.28)] px-8 py-7 text-white shadow-[0_28px_100px_rgba(15,23,42,0.34)] backdrop-blur-[18px] md:px-10 md:py-8">
				<h1
					class="hero-title-animation text-[clamp(3rem,6.5vw,5.6rem)] font-bold leading-[1.08] tracking-[0.04em] drop-shadow-[0_14px_45px_rgba(0,0,0,0.34)]"
					style="animation-delay: 140ms"
				>
					{siteConfig.homeHero.title}
				</h1>
				<p
					class="hero-subtitle-animation mt-4 text-[clamp(1rem,1.8vw,1.3rem)] font-semibold tracking-[0.2em] text-white/92"
					style="animation-delay: 300ms"
				>
					{siteConfig.homeHero.subtitle}
				</p>
			</div>
		</div>
	</div>

	<div class="absolute inset-x-0 bottom-8 z-10 flex justify-center px-6">
		<a
			href="#home-posts"
			class="hero-subtitle-animation rounded-[999px] border border-white/28 bg-white/14 px-6 py-3 text-sm font-semibold tracking-[0.2em] text-white/90 shadow-[0_18px_60px_rgba(15,23,42,0.24)] backdrop-blur-[16px] transition hover:bg-white/18"
			style="animation-delay: 420ms"
		>
			进入首页
		</a>
	</div>
</section>
