---
import { siteConfig } from "../config";
---

<section
	id="home-hero"
	class="relative flex min-h-[100svh] items-center justify-center px-6 pb-24 pt-28 text-center md:pb-28 md:pt-32"
>
	<div class="absolute inset-0 bg-gradient-to-b from-slate-900/16 via-slate-900/10 to-slate-950/38"></div>
	<div class="relative z-10 w-full max-w-6xl text-white">
		<div
			class="mx-auto max-w-4xl rounded-[2rem] border border-white/28 bg-white/12 px-8 py-8 shadow-[0_30px_120px_rgba(15,23,42,0.32)] backdrop-blur-[18px] md:px-12 md:py-10"
		>
			<p
				class="hero-title-animation text-[clamp(3.3rem,8.6vw,7.2rem)] font-bold leading-[1.04] tracking-[0.04em] drop-shadow-[0_14px_45px_rgba(0,0,0,0.34)]"
				style="animation-delay: 140ms"
			>
				{siteConfig.homeHero.title}
			</p>
			<p
				class="hero-subtitle-animation mt-5 text-[clamp(1rem,2vw,1.35rem)] font-medium tracking-[0.3em] text-white/90"
				style="animation-delay: 320ms"
			>
				{siteConfig.homeHero.subtitle}
			</p>
		</div>
	</div>
</section>
