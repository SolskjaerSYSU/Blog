---
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Layout from "@layouts/Layout.astro";
import { url } from "../../utils/url-utils";
---

<Layout title="Photography Works" description="摄影作品展示页">
	<div
		id="top-row"
		class="z-50 pointer-events-none fixed inset-x-0 top-0 transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto"
	>
		<div id="navbar-wrapper" class="pointer-events-auto pt-0 transition-all">
			<Navbar></Navbar>
		</div>
	</div>

	<section class="relative h-[100svh] overflow-hidden">
		<div class="absolute inset-0">
			<ImageWrapper
				src="assets/images/DSC_1724.jpg"
				alt="Photography works hero image"
				class="h-full w-full"
				position="center"
			/>
		</div>
		<div class="absolute inset-0 bg-gradient-to-b from-slate-950/16 via-slate-950/8 to-slate-950/34"></div>

		<div class="relative z-10 flex h-full flex-col items-center justify-center px-6 pb-24 pt-28 text-center">
			<div class="rounded-[2rem] border border-white/24 bg-[rgba(166,184,199,0.22)] px-8 py-7 shadow-[0_30px_100px_rgba(15,23,42,0.3)] backdrop-blur-[18px] md:px-12 md:py-9">
				<h1
					class="hero-title-animation text-[clamp(3rem,7vw,5.6rem)] font-semibold italic leading-[1.02] tracking-[0.02em] text-white"
					style={`animation-delay: 120ms; font-family: "Palatino Linotype", "Book Antiqua", Georgia, serif;`}
				>
					Photography Works
				</h1>
				<p
					class="hero-subtitle-animation mt-4 text-[clamp(1rem,2vw,1.24rem)] font-semibold tracking-[0.2em] text-white/92"
					style="animation-delay: 280ms"
				>
					摄影作品
				</p>
			</div>
		</div>

		<div class="absolute inset-x-0 bottom-8 z-10 flex justify-center px-6">
			<a
				href="#photography-gallery"
				class="hero-subtitle-animation rounded-[999px] border border-white/26 bg-white/14 px-7 py-3 text-sm font-semibold tracking-[0.2em] text-white/90 shadow-[0_18px_60px_rgba(15,23,42,0.24)] backdrop-blur-[16px] transition hover:bg-white/18"
				style="animation-delay: 420ms"
			>
				查看作品
			</a>
		</div>
	</section>

	<section
		id="photography-gallery"
		class="bg-[linear-gradient(180deg,#e0ecff_0%,#eef5ff_30%,#f8fbff_100%)] px-6 py-16 md:px-8 md:py-20"
	>
		<div class="mx-auto max-w-[var(--page-width)] space-y-8">
			<div class="rounded-[2.4rem] border border-white/60 bg-white/80 px-8 py-10 shadow-[0_24px_80px_rgba(148,163,184,0.16)] backdrop-blur-[14px] md:px-10 md:py-12">
				<p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">
					Photo Archive
				</p>
				<h2 class="mt-4 text-[clamp(2rem,3vw,3.2rem)] font-bold tracking-[0.03em] text-slate-900">
					摄影作品分区
				</h2>
				<p class="mt-5 max-w-4xl text-[1rem] leading-8 text-slate-700">
					这里会整理风景、城市、光影与日常观察相关的摄影作品。现在已经独立成单独子页面，后续可以继续扩成专题相册、城市分类、器材记录或时间线展示。
				</p>
			</div>

			<div class="grid gap-6 md:grid-cols-2">
				<div class="overflow-hidden rounded-[2rem] border border-white/60 bg-white/80 shadow-[0_20px_70px_rgba(148,163,184,0.14)] backdrop-blur-[14px]">
					<ImageWrapper
						src="assets/images/DSC_1724.jpg"
						alt="Photography preview one"
						class="aspect-[4/3] w-full"
						position="center"
					/>
					<div class="p-6">
						<p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
							Preview A
						</p>
						<h3 class="mt-3 text-2xl font-bold text-slate-900">
							城市与空间
						</h3>
						<p class="mt-4 text-[1rem] leading-8 text-slate-700">
							这里预留给城市天际线、建筑、街道空间和都市观察类摄影作品。后续我们可以把每张照片继续接成独立作品卡。
						</p>
					</div>
				</div>

				<div class="rounded-[2rem] border border-white/60 bg-white/80 p-7 shadow-[0_20px_70px_rgba(148,163,184,0.14)] backdrop-blur-[14px]">
					<p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
						Preview B
					</p>
					<h3 class="mt-4 text-2xl font-bold text-slate-900">
						风景与光影
					</h3>
					<p class="mt-4 text-[1rem] leading-8 text-slate-700">
						这里预留给风景、自然光、日落夜景与氛围感作品。等你整理好更多照片后，我们可以继续做成分组相册或瀑布流展示。
					</p>
				</div>
			</div>

			<div class="flex justify-center pt-2">
				<a
					href={url("/artworks/")}
					class="rounded-[999px] border border-slate-300 bg-white/78 px-7 py-3 text-sm font-semibold tracking-[0.2em] text-slate-700 shadow-[0_14px_40px_rgba(148,163,184,0.14)] transition hover:bg-white"
				>
					返回作品首页
				</a>
			</div>

			<div class="pt-4">
				<Footer />
			</div>
		</div>
	</section>
</Layout>
