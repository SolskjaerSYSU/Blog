---
import { Icon } from "astro-icon/components";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Profile from "@components/widget/Profile.astro";
import Layout from "@layouts/Layout.astro";

const techStack = [
	{
		label: "C",
		short: "C",
		bg: "bg-[#4354b8]",
		textClass: "text-white",
	},
	{
		label: "HTML5",
		icon: "fa6-brands:html5",
		bg: "bg-[#eb5b20]",
		textClass: "text-white",
	},
	{
		label: "CSS3",
		icon: "fa6-brands:css3-alt",
		bg: "bg-[#1572b6]",
		textClass: "text-white",
	},
	{
		label: "JavaScript",
		icon: "fa6-brands:js",
		bg: "bg-[#f7df1e]",
		textClass: "text-slate-900",
	},
	{
		label: "Python",
		icon: "fa6-brands:python",
		bg: "bg-[#366a96]",
		textClass: "text-white",
	},
	{
		label: "Git",
		icon: "fa6-brands:git-alt",
		bg: "bg-[#f05133]",
		textClass: "text-white",
	},
	{
		label: "Markdown",
		icon: "material-symbols:markdown-rounded",
		bg: "bg-[#2b2d42]",
		textClass: "text-white",
	},
	{
		label: "C++",
		short: "C++",
		bg: "bg-[#1f3f8f]",
		textClass: "text-white",
	},
	{
		label: "Linux",
		icon: "fa6-brands:linux",
		bg: "bg-[#111827]",
		textClass: "text-white",
	},
	{
		label: "MATLAB",
		short: "Mx",
		bg: "bg-[linear-gradient(135deg,#ff7f50_0%,#ffb347_45%,#2f80ed_100%)]",
		textClass: "text-white",
	},
];
---

<Layout title="About" description="About SolskjaerSYSU">
	<div
		id="top-row"
		class="pointer-events-none fixed inset-x-0 top-0 z-50 mx-auto max-w-[var(--page-width)] px-0 transition-all duration-700 md:px-4"
	>
		<div id="navbar-wrapper" class="pointer-events-auto pt-0 transition-all">
			<Navbar />
		</div>
	</div>

	<section class="relative min-h-[100svh] overflow-hidden">
		<div class="absolute inset-0">
			<ImageWrapper
				src="assets/images/DSC_1724.jpg"
				alt="About page hero image"
				class="h-full w-full"
				position="center"
			/>
		</div>
		<div class="absolute inset-0 bg-gradient-to-b from-slate-950/12 via-slate-950/12 to-slate-950/40"></div>

		<div class="relative z-10 flex min-h-[100svh] items-center justify-center px-6 pb-20 pt-28 text-center md:px-8 md:pt-32">
			<div class="w-full max-w-[var(--page-width)]">
				<div class="mx-auto w-full max-w-4xl rounded-[2rem] border border-white/30 bg-[rgba(171,192,205,0.22)] px-8 py-10 shadow-[0_30px_100px_rgba(15,23,42,0.32)] backdrop-blur-[18px] md:px-14 md:py-14">
					<p class="text-sm font-semibold uppercase tracking-[0.32em] text-white/76">
						Profile & Notes
					</p>
					<h1 class="mt-5 font-serif text-[clamp(3.5rem,7vw,7rem)] italic leading-[0.95] tracking-[0.03em] text-white drop-shadow-[0_12px_30px_rgba(15,23,42,0.28)]">
						About Me
					</h1>
				</div>

				<a
					href="#about-panels"
					class="mt-10 inline-flex rounded-[999px] border border-white/28 bg-white/16 px-8 py-4 text-sm font-semibold uppercase tracking-[0.22em] text-white shadow-[0_18px_45px_rgba(15,23,42,0.18)] backdrop-blur-[10px] transition hover:bg-white/24"
				>
					Explore
				</a>
			</div>
		</div>
	</section>

	<section
		id="about-panels"
		class="bg-[linear-gradient(180deg,#dbe6fb_0%,#edf3ff_24%,#f8fbff_100%)] px-6 pb-14 pt-14 md:px-8 md:pb-20 md:pt-16"
	>
		<div class="mx-auto grid max-w-[var(--page-width)] gap-6 lg:grid-cols-[18rem_minmax(0,1fr)]">
			<div class="lg:sticky lg:top-24 lg:self-start">
				<Profile />
			</div>

			<div class="grid gap-6 xl:grid-cols-2">
				<div class="card-base border border-white/65 bg-white/78 px-8 py-8 shadow-[0_24px_80px_rgba(148,163,184,0.16)] xl:col-span-2">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">
						About Me
					</p>
					<h2 class="mt-4 text-[clamp(2rem,3vw,3.1rem)] font-bold tracking-[0.03em] text-slate-950">
						关于我
					</h2>
					<div class="mt-5 space-y-4 text-[1rem] leading-8 text-slate-700">
						<p>
							这里是 SolskjaerSYSU 的个人博客，也是我整理学习笔记、作品与长期项目的地方。
						</p>
						<p>
							我主要在这里记录 C++、数据结构和编程实践中的学习过程，也会放自己的摄影、绘画、Github 项目以及一些随笔。
						</p>
						<p>
							我希望把这里慢慢做成一个持续生长的个人档案库，既能沉淀技术，也能保留兴趣、观察和表达。
						</p>
					</div>
				</div>

				<div class="card-base border border-white/65 bg-white/78 px-8 py-8 shadow-[0_24px_80px_rgba(148,163,184,0.16)] xl:col-span-2">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">
						Github Activity
					</p>
					<h2 class="mt-4 text-[clamp(2rem,3vw,3rem)] font-bold tracking-[0.03em] text-slate-950">
						Github贡献量可视化
					</h2>
					<a
						href="https://github.com/SolskjaerSYSU"
						target="_blank"
						rel="noreferrer"
						class="mt-6 block overflow-hidden rounded-[1.6rem] border border-slate-200/80 bg-white p-4 transition hover:border-slate-300"
					>
						<img
							src="https://ghchart.rshah.org/2563eb/SolskjaerSYSU"
							alt="Github contribution chart for SolskjaerSYSU"
							class="w-full rounded-[1rem]"
						/>
					</a>
				</div>

				<div class="card-base border border-white/65 bg-white/78 px-8 py-8 shadow-[0_24px_80px_rgba(148,163,184,0.16)]">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">
						Skills
					</p>
					<h2 class="mt-4 text-[clamp(2rem,3vw,3rem)] font-bold tracking-[0.03em] text-slate-950">
						技术栈
					</h2>
					<div class="mt-6 flex flex-wrap gap-4">
						{techStack.map((item) => (
							<div class="flex flex-col items-center gap-2">
								<div
									class:list={[
										"flex h-24 w-24 items-center justify-center rounded-[1.65rem] shadow-[0_16px_32px_rgba(148,163,184,0.18)]",
										item.bg,
									]}
								>
									{item.icon ? (
										<Icon
											name={item.icon}
											class:list={["text-[3rem]", item.textClass]}
										/>
									) : (
										<span class:list={["text-[2rem] font-black tracking-tight", item.textClass]}>
											{item.short}
										</span>
									)}
								</div>
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">
									{item.label}
								</span>
							</div>
						))}
					</div>
				</div>

				<div class="card-base border border-white/65 bg-white/78 px-8 py-8 shadow-[0_24px_80px_rgba(148,163,184,0.16)]">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">
						Personality
					</p>
					<h2 class="mt-4 text-[clamp(2rem,3vw,3rem)] font-bold tracking-[0.03em] text-slate-950">
						MBTI
					</h2>
					<div class="mt-6 rounded-[1.8rem] border border-slate-200/80 bg-[linear-gradient(135deg,#f7f2ff_0%,#fefbff_100%)] px-6 py-6 shadow-[0_20px_40px_rgba(167,139,250,0.12)]">
						<div class="mb-4 inline-flex rounded-[999px] bg-[#8b2cf5] px-4 py-2 text-sm font-bold tracking-[0.08em] text-white shadow-[0_12px_30px_rgba(139,44,245,0.25)]">
							INTJ
						</div>
						<div class="flex flex-col items-center gap-5 md:flex-row md:items-end">
							<div class="flex h-44 w-44 items-center justify-center rounded-[2rem] bg-[linear-gradient(180deg,#efe3ff_0%,#ffffff_100%)] shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_10px_24px_rgba(148,163,184,0.12)]">
								<Icon name="material-symbols:architecture-rounded" class="text-[6.5rem] text-[#7c3aed]" />
							</div>
							<div class="pb-2 text-center md:text-left">
								<div class="text-4xl font-black tracking-[0.06em] text-slate-900">建筑师</div>
								<div class="mt-2 text-lg font-semibold tracking-[0.18em] text-[#8b2cf5]">
									The Architect
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="xl:col-span-2">
					<Footer />
				</div>
			</div>
		</div>
	</section>
</Layout>
